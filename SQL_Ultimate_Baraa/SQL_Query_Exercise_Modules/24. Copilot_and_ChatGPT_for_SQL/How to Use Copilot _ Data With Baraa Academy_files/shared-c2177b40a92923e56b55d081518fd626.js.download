sel.appearance.var_description.accessibleColorOnColorBackground":"The color of text appearing on top of any var(--colorBackground) background.","easel.appearance.var_description.accessibleColorOnColorDanger":"The color of text appearing on top of any var(--colorDanger) background.","easel.appearance.var_description.accessibleColorOnColorPrimary":"The color of text appearing on top of any var(--colorPrimary) background.","easel.appearance.var_description.accessibleColorOnColorSuccess":"The color of text appearing on top of any var(--colorSuccess) background.","easel.appearance.var_description.accessibleColorOnColorWarning":"The color of text appearing on top of any var(--colorWarning) background.","easel.appearance.var_description.accordionItemLabelColorText":"The text color of the label in accordion items.","easel.appearance.var_description.accordionItemLabelFontSize":"The font size of the label in accordion items.","easel.appearance.var_description.accordionItemLabelFontWeight":"The font weight of the label in accordion items.","easel.appearance.var_description.accordionItemLabelSelectedColorText":"The text color of the label in a selected .AccordionItem.","easel.appearance.var_description.accordionItemLabelSelectedFontWeight":"The font weight of the label in a selected .AccordionItem.","easel.appearance.var_description.accordionItemSpacing":"The vertical spacing between accordion items. This is only applicable when spacedAccordionItems is true.","easel.appearance.var_description.blockLogoColor":"The logo variation to display inside .Block components; either light or dark.","easel.appearance.var_description.borderRadius":"The border radius used for tabs, inputs, and other components in the Element.","easel.appearance.var_description.buttonBorderRadius":"The border radius used for buttons. By default, buttons use borderRadius.","easel.appearance.var_description.buttonExpressCheckoutBorderRadius":"The border radius used for express checkout buttons. By default, uses buttonBorderRadius.","easel.appearance.var_description.buttonColorBackground":"The color used for the background of buttons. By default, buttons use colorPrimary.","easel.appearance.var_description.buttonColorText":"The text color used for buttons. By default, buttons use accessibleColorOnColorPrimary.","easel.appearance.var_description.buttonFontSize":"The font size used for buttons.","easel.appearance.var_description.buttonFontWeight":"The font weight used for buttons.","easel.appearance.var_description.buttonPadding":"The padding used for buttons.","easel.appearance.var_description.colorBackground":"The color used for the background of inputs, tabs, and other components in the Element.","easel.appearance.var_description.colorDanger":"A color used to indicate errors or destructive actions in the Element.","easel.appearance.var_description.colorPrimary":"A primary color used throughout the Element. Set this to your primary brand color.","easel.appearance.var_description.colorSuccess":"A color used to indicate positive actions or successful results in the Element.","easel.appearance.var_description.colorText":"The default text color used in the Element.","easel.appearance.var_description.colorTextPlaceholder":"The color used for input placeholder text in the Element.","easel.appearance.var_description.colorTextSecondary":"The color used for text of secondary importance. For example, this color is used for the label of a tab that isn’t currently selected.","easel.appearance.var_description.colorWarning":"A color used to indicate potentially destructive actions in the Element.","easel.appearance.var_description.focusBoxShadow":"The box-shadow used for focused components.","easel.appearance.var_description.focusOutline":"The outline used for focused components.","easel.appearance.var_description.fontFamily":"The font family used throughout Elements. Elements supports custom fonts by passing the fonts option to initCheckout or CheckoutProvider.","easel.appearance.var_description.fontLineHeight":"The line-height setting of text in the Element.","easel.appearance.var_description.fontSize2Xl":"The font size of double-extra large text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSize2Xs":"The font size of double-extra small text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSize3Xs":"The font size of triple-extra small text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSizeBase":"The font size that’s set on the root of the Element. By default, other font size variables such as fontSizeXs or fontSizeSm are scaled from this value using rem units. Make sure that you choose a font size of at least 16px for input fields on mobile.","easel.appearance.var_description.fontSizeLg":"The font size of large text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSizeSm":"The font size of small text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSizeXl":"The font size of extra-large text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSizeXs":"The font size of extra-small text in the Element. By default this is scaled from var(--fontSizeBase) using rem units.","easel.appearance.var_description.fontSmooth":"What text anti-aliasing settings to use in the Element. It can be always, auto, or never.","easel.appearance.var_description.fontVariantLigatures":"The font-variant-ligatures setting of text in the Element.","easel.appearance.var_description.fontVariationSettings":"The font-variation-settings setting of text in the Element.","easel.appearance.var_description.fontWeightBold":"The font weight used for bold text.","easel.appearance.var_description.fontWeightLight":"The font weight used for light text.","easel.appearance.var_description.fontWeightMedium":"The font weight used for medium text.","easel.appearance.var_description.fontWeightNormal":"The font weight used for normal text.","easel.appearance.var_description.gridColumnSpacing":"The spacing between columns in the grid used for the Element layout.","easel.appearance.var_description.gridRowSpacing":"The spacing between rows in the grid used for the Element layout.","easel.appearance.var_description.iconCardCvcColor":"The color of the CVC variant of the card icon.","easel.appearance.var_description.iconCardCvcErrorColor":"The color of the CVC variant of the card icon when the CVC field has invalid input.","easel.appearance.var_description.iconCardErrorColor":"The color of the card icon when it’s in an error state.","easel.appearance.var_description.iconCheckmarkColor":"The color of checkmarks displayed within components like .Checkbox.","easel.appearance.var_description.iconChevronDownColor":"The color of arrow icons displayed within select inputs.","easel.appearance.var_description.iconChevronDownHoverColor":"The color of arrow icons when hovered.","easel.appearance.var_description.iconCloseColor":"The color of close icons, used for indicating a dismissal or close action.","easel.appearance.var_description.iconCloseHoverColor":"The color of close icons when hovered.","easel.appearance.var_description.iconColor":"The default color used for icons in the Element, such as the icon appearing in the card tab.","easel.appearance.var_description.iconHoverColor":"The color of icons when hovered.","easel.appearance.var_description.iconLoadingIndicatorColor":"The color of the spinner in loading indicators.","easel.appearance.var_description.iconMenuColor":"The color of menu icons used to indicate a set of additional actions.","easel.appearance.var_description.iconMenuHoverColor":"The color of menu icons when hovered.","easel.appearance.var_description.iconMenuOpenColor":"The color of menu icons when opened.","easel.appearance.var_description.iconPasscodeDeviceColor":"The color of the passcode device icon, used to indicate a message has been sent to the user’s mobile device.","easel.appearance.var_description.iconPasscodeDeviceHoverColor":"The color of the passcode device icon when hovered.","easel.appearance.var_description.iconPasscodeDeviceNotificationColor":"The color of the notification indicator displayed over the passcode device icon.","easel.appearance.var_description.iconRedirectColor":"The color of the redirect icon that appears for redirect-based payment methods.","easel.appearance.var_description.inputBoxShadow":"The box shadow applied to inputs.","easel.appearance.var_description.inputColorBorder":"The border color of inputs.","easel.appearance.var_description.inputFocusBoxShadow":"The box shadow applied to inputs when focused.","easel.appearance.var_description.inputFocusColorBorder":"The border color of inputs when focused.","easel.appearance.var_description.labelColorText":"The text color of labels.","easel.appearance.var_description.labelFontSize":"The font size of labels.","easel.appearance.var_description.labelFontWeight":"The font weight of labels.","easel.appearance.var_description.labelSpacing":"The spacing between labels and their associated inputs. This is not applicable when using floating labels.","easel.appearance.var_description.logoColor":"A preference for which logo variations to display; either light or dark.","easel.appearance.var_description.pickerItemSpacing":"The spacing between .PickerItem components rendered within the .Picker component.","easel.appearance.var_description.spacingUnit":"The base spacing unit that all other spacing is derived from. Increase or decrease this value to make your layout more or less spacious.","easel.appearance.var_description.tabIconColor":"The color of icons appearing in a tab.","easel.appearance.var_description.ta